# =============================================================================
# DATABASE
# =============================================================================
# Production (Neon): paste the connection string from Neon Dashboard → Connect.
# Use the pooled string on Vercel/serverless if Neon offers it; include ?sslmode=require if needed.
# Local dev: point DATABASE_URL at the same Neon branch, or run a local Postgres and paste its URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# =============================================================================
# SITE & DOMAIN (production)
# =============================================================================
# Public URL of your site — NO trailing slash. Required for payment links, emails, referrals, webhooks.
# Examples: https://www.filerightsolutions.com  or  https://filerightsolutions.com
SITE_BASE_URL="http://localhost:3000"

SITE_NAME="FileRight Solutions"
NEXT_PUBLIC_SITE_NAME="FileRight Solutions"

# Optional: extra hosts allowed for Server Actions (comma or space separated), e.g. apex + www:
# SERVER_ACTION_ALLOWED_ORIGINS="https://yourdomain.com https://www.yourdomain.com"
# Usually unnecessary if SITE_BASE_URL is set — next.config.js also adds VERCEL_URL on Vercel.

# =============================================================================
# PROFESSIONAL EMAIL (matches your domain / email hosting)
# =============================================================================
# SUPPORT_EMAIL: shown to customers, Reply-To on billing mail, and default From display name target.
SUPPORT_EMAIL="support@yourdomain.com"

# SMTP: use the settings from your email provider (same place you bought domain email).
# Common patterns (confirm in your provider’s “SMTP” / “mail client” docs):
#
#   Google Workspace     SMTP_HOST=smtp.gmail.com        SMTP_PORT=587
#   Microsoft 365        SMTP_HOST=smtp.office365.com   SMTP_PORT=587
#   Zoho Mail              SMTP_HOST=smtp.zoho.com        SMTP_PORT=587
#   cPanel / generic       SMTP_HOST=mail.yourdomain.com  SMTP_PORT=587 (or 465 for SSL)
#
# SMTP_USER = full mailbox address (e.g. support@yourdomain.com)
# SMTP_PASS = app password or mailbox password (many providers require an “app password” if 2FA is on)
#
# SMTP_FROM = what recipients see as sender. Should be an address you are allowed to send as.
# Example: "FileRight Solutions <support@yourdomain.com>"
#
# DNS (at your domain registrar or DNS host — not in this file): add SPF (and DKIM/DMARC if your
# provider gives you records). That improves deliverability so billing mail does not land in spam.

# In development, leaving SMTP_HOST / SMTP_USER / SMTP_PASS empty uses safe log-only mail (no send).
# In production, those three must be set or sending will fail.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="FileRight Solutions <support@yourdomain.com>"

# =============================================================================
# SESSION & ADMIN
# =============================================================================
SESSION_SECRET="replace_with_a_long_random_secret"

ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="replace_with_strong_password"

# =============================================================================
# PAYMENTS (Dragonpay)
# =============================================================================
DRAGONPAY_MERCHANT_ID=""
DRAGONPAY_SECRET=""

# =============================================================================
# PAYMENTS (PayMongo)
# =============================================================================
# Secret key used by server routes to create checkout sessions.
PAYMONGO_SECRET_KEY=""
# Optional public key (only needed for client-side PayMongo JS flows).
PAYMONGO_PUBLIC_KEY=""
# Webhook signing secret from PayMongo Dashboard → Webhooks → your endpoint → show/copy secret.
# When set, /api/paymongo/webhook rejects POSTs with a bad Paymongo-Signature (recommended in production).
PAYMONGO_WEBHOOK_SECRET=""
# Comma-separated method types. Example: gcash,paymaya,card
PAYMONGO_PAYMENT_METHOD_TYPES="gcash"

# =============================================================================
# QUOTED BILLING (/admin/billing)
# =============================================================================
REFERRAL_FEE_REDUCTION_PERCENT="10"
MIN_QUOTED_PAYMENT_PHP="1"

# =============================================================================
# OTHER
# =============================================================================
CRON_KEY=""

# Optional: override where 1701A evaluation PDF copies go (default in code may be set for your ops inbox)
# EVALUATION_PDF_NOTIFY_EMAIL="you@example.com"
