generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ServicePackage {
  id          String   @id @default(cuid())
  // Internal packages e.g. QUOTED_BILLING for admin-set fees
  code        String?  @unique
  name        String
  description String
  inclusions  String
  exclusions  String
  turnaround  String
  pricePhp    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

model Order {
  id            String  @id @default(cuid())
  orderId       String  @unique
  status        String  @default("PENDING")
  amountPhp     Int
  customerName  String
  customerEmail String
  customerPhone String?

  uploadToken String    @unique
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  packageId String
  pkg       ServicePackage @relation(fields: [packageId], references: [id])

  payments  Payment[]
  uploads   Upload[]
  emailLogs EmailLog[]
  filingTask FilingTask?
  sourcedFromQuote PaymentQuote? @relation("QuoteToOrder")
}

model FilingTask {
  id String @id @default(cuid())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status String @default("READY_TO_FILE") // READY_TO_FILE | IN_PROGRESS | FILED | ON_HOLD | QC_DONE
  assigneeName String?
  filedByName String?
  filingReference String?
  holdReason String?
  notes String?

  dueAt DateTime?
  startedAt DateTime?
  filedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([dueAt])
}

model Payment {
  id          String   @id @default(cuid())
  orderIdRef  String
  provider    String
  method      String?
  providerRef String?
  status      String
  rawPayload  String
  createdAt   DateTime @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
}

model Upload {
  id          String   @id @default(cuid())
  filename    String
  storagePath String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
}

model EmailLog {
  id                String    @id @default(cuid())
  type              String
  toEmail           String
  subject           String
  sentAt            DateTime?
  failedAt          DateTime?
  failReason        String?
  providerMessageId String?
  createdAt         DateTime  @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  @@unique([orderId, type])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ScheduledEmail {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  type    String
  toEmail String
  subject String
  body    String
  sendAt  DateTime

  sentAt     DateTime?
  failedAt   DateTime?
  failReason String?
  attemptCount Int @default(0)
  lastAttemptAt DateTime?
  nextAttemptAt DateTime?
  idempotencyKey String? @unique
  lastProviderMessageId String?

  // optional linkage
  evaluationId String?
  userId       String?

  @@index([sendAt])
  @@index([nextAttemptAt])
  @@index([sentAt, failedAt, nextAttemptAt])
  @@index([evaluationId])
  @@index([userId])
}

model EmailSuppression {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String
  source    String   @default("manual")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt])
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String?
  passwordHash String
  role         String   @default("CUSTOMER") // CUSTOMER | ADMIN | AGENT
  /// When true, this user may use /agent/login and /agent-dashboard (same email as customer/admin).
  agentPortalEnabled Boolean @default(false)
  /// Public token for /register?agentRef=… (agent program counts only). Never use `referralCode` here — that drives client ReferralEvent / payable credit.
  agentReferralLinkCode String? @unique
  /// For manual GCash payouts (agents); normalized digits e.g. 09XXXXXXXXX.
  agentPayoutGcashNumber       String?
  /// Registered name on GCash (for manual payout verification).
  agentPayoutGcashAccountName String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referralCode      String          @unique
  referralsSent     ReferralEvent[] @relation("Referrer")
  referralsReceived ReferralEvent[] @relation("ReferredUser")

  evaluations                Evaluation[]
  evaluation1701ASubmissions Evaluation1701ASubmission[]
  passwordResetTokens        PasswordResetToken[]
  paymentQuotes              PaymentQuote[]
  filingCompleteNotifySends  FilingCompleteNotifySend[]

  agentReferralSubmissions AgentReferralSubmission[] @relation("AgentReferralByAgent")
  agentReferralMatchedIn   AgentReferralSubmission[] @relation("AgentReferralMatchedUser")
}

/// External agent typed a referred client name; matched to a customer after name rules; payout after paid + delay.
model AgentReferralSubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agentId String
  agent   User   @relation("AgentReferralByAgent", fields: [agentId], references: [id], onDelete: Cascade)

  /// Raw name as entered (may omit middle name vs account full name).
  nameEntered String @db.Text

  matchedUserId String?
  matchedUser   User?   @relation("AgentReferralMatchedUser", fields: [matchedUserId], references: [id], onDelete: SetNull)

  /// When we first saw a paid service order for the matched customer.
  paidDetectedAt DateTime?

  /// Automatic payout marker (72h+ after submission, customer paid). No bank integration—ledger only.
  payoutCompletedAt DateTime?

  amountPhp Int @default(100)

  /// If set, this row never receives a payout (e.g. duplicate referral for same client).
  payoutBlockedReason String?

  @@index([agentId, createdAt])
  @@index([matchedUserId])
  @@index([payoutCompletedAt])
}

/// Admin-sent “filing processed” notification; used for “last sent” on filing email UI.
model FilingCompleteNotifySend {
  id     String   @id @default(cuid())
  sentAt DateTime @default(now())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
}

model PaymentQuote {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  baseAmountPhp Int
  // Snapshot when order is created
  appliedDiscountPhp Int?
  finalChargedPhp    Int?

  adminMemo  String?
  clientNote String?

  status String @default("OPEN")

  resultOrderDbId String? @unique
  resultOrder     Order?  @relation("QuoteToOrder", fields: [resultOrderDbId], references: [id])

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

model ReferralEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // who referred
  referrerId String
  referrer   User   @relation("Referrer", fields: [referrerId], references: [id])

  // who used the referral link (the new user)
  referredUserId String @unique
  referredUser   User   @relation("ReferredUser", fields: [referredUserId], references: [id])

  // becomes true only when the referred client completes free evaluation
  evaluationCompleted Boolean @default(false)

  // opposite side for Evaluation.referralEvent
  evaluations Evaluation[]
}

model Evaluation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Increments on each successful 1701A portal submit (first = 1). Used in admin list to flag resubmissions.
  submit1701aCount Int @default(0)

  status  String  @default("DRAFT") // DRAFT | SUBMITTED | IN_REVIEW | DONE
  taxYear String?
  // Saved form data (draft/submitted). Stored here even when no PDF is generated.
  payloadJson String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  referralEventId String?
  referralEvent   ReferralEvent? @relation(fields: [referralEventId], references: [id])

  // 1-to-1 submission
  submission1701A Evaluation1701ASubmission?

  @@index([userId, createdAt])
  @@index([referralEventId])
}

model Evaluation1701ASubmission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  /// Last successful GET /admin/evaluations/[id]/pdf (admin fetched PDF).
  adminPdfDownloadedAt DateTime?
  /// `Evaluation.submit1701aCount` when `adminPdfDownloadedAt` was set; must match current count to show “Downloaded” after resubmits.
  adminPdfDownloadedSubmitOrdinal Int?

  /// Processor1 dashboard: last successful PDF GET for the current submit version (client snapshot).
  processor1PdfDownloadedAt DateTime?
  processor1PdfDownloadedSubmitOrdinal Int?
  /// Processor2 dashboard: last successful PDF GET for the current submit version (processed PDF).
  processor2PdfDownloadedAt DateTime?
  processor2PdfDownloadedSubmitOrdinal Int?

  // FULL FORM DATA (JSON string)
  payloadJson String

  // PDF metadata (pdf will be generated server-side)
  pdfFilename  String
  pdfPath      String
  pdfMimeType  String @default("application/pdf")
  pdfSizeBytes Int

  /// Client-view snapshot PDF (verbatim portal values). Processor1 downloads use this; admin/processor2 use `pdfPath` / payload regenerate rules above.
  clientSnapshotPdfFilename  String?
  clientSnapshotPdfPath      String?
  clientSnapshotPdfMimeType  String?
  clientSnapshotPdfSizeBytes Int?

  evaluationId String     @unique
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([createdAt])
}

model AdminAudit {
  id        String   @id @default(cuid())
  action    String
  details   String
  createdAt DateTime @default(now())
}

model SiteSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
